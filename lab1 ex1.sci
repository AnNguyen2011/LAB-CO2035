// Tạo vector x = 1:4
x = 1:4;

// 1. Tạo vector (x1+1, x2+1, x3+1, x4+1)
v1 = x + 1
// Tạo vector x = 1:4 và y = 5:8
x = 1:4;
y = 5:8;

// 2. Tạo vector (x1y1, x2y2, x3y3, x4y4)
v2 = x .* y
// Tạo vector x gồm 10 giá trị trong khoảng [0, π]
x = linspace(0, %pi, 10);

// 3. Tạo vector (sin(x1), sin(x2), ..., sin(x10))
v3 = sin(x)
